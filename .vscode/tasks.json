{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check Rhai Scripts",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--quiet"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "rhai",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^Failed to compile (\\w+) at line (\\d+), column (\\d+): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}