from PIL import Image, ImageDraw, ImageFont
import os

def create_pgm_icon(name, output_path, size=(68, 68), font_size=12):
    """
    Creates a grayscale PGM icon with the given name centered.
    """
    img = Image.new('L', size, color=255)  # White background (255 is white in 'L' mode)
    d = ImageDraw.Draw(img)

    try:
        # Try to use a default sans-serif font
        font = ImageFont.truetype("arial.ttf", font_size)
    except IOError:
        # Fallback to a generic PIL font if specific font not found
        font = ImageFont.load_default()

    # Calculate text size and position to center it
    # Use textbbox for more accurate bounding box calculation in Pillow 9.0+
    bbox = d.textbbox((0, 0), name, font=font)
    text_width = bbox[2] - bbox[0]
    text_height = bbox[3] - bbox[1]

    x = (size[0] - text_width) / 2
    y = (size[1] - text_height) / 2

    d.text((x, y), name, fill=0, font=font) # Black text (0 is black)

    img.save(output_path, "PPM", PGM=True) # PPM with PGM=True saves as P5 PGM

def combine_icons_into_spritesheet(icon_paths, output_path, icon_size=(68, 68)):
    """
    Combines multiple PGM icons into a single horizontal sprite sheet.
    """
    if not icon_paths:
        return

    # Assuming all icons are the same size
    icon_width, icon_height = icon_size
    total_width = len(icon_paths) * icon_width

    spritesheet = Image.new('L', (total_width, icon_height), color=255) # White background

    x_offset = 0
    for icon_path in icon_paths:
        icon = Image.open(icon_path)
        spritesheet.paste(icon, (x_offset, 0))
        x_offset += icon_width

    spritesheet.save(output_path, "PPM", PGM=True)
    print(f"Generated sprite sheet: {output_path}")

def generate_app_icons(output_dir):
    """
    Generates PGM icons for the canonical apps and combines them into a sprite sheet.
    """
    apps = ["Notes", "Address", "Date", "ToDo"]
    if not os.path.exists(output_dir):
        os.makedirs(output_dir)

    icon_paths = []
    for app_name in apps:
        filename = os.path.join(output_dir, f"{app_name.lower()}_icon.pgm")
        create_pgm_icon(app_name, filename)
        print(f"Generated {filename}")
        icon_paths.append(filename)

    spritesheet_path = os.path.join(output_dir, "app_icons_spritesheet.pgm")
    combine_icons_into_spritesheet(icon_paths, spritesheet_path)


if __name__ == "__main__":
    script_dir = os.path.dirname(__file__)
    assets_sprites_dir = os.path.join(script_dir, "assets", "sprites")
    generate_app_icons(assets_sprites_dir)

