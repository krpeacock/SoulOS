        let (width, height, pixels) = load_pgm(&sprite_sheet_path)
            .expect(&format!("Failed to load sprite sheet: {}", sprite_sheet_path.display()));

        let sprite_sheet_inverted_path = PathBuf::from(SPRITE_SHEET_INVERTED_PATH);
        let (width_inv, height_inv, pixels_inv) = load_pgm(&sprite_sheet_inverted_path)
